generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  MAINTENANCE
  LOST
  RETIRED
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  status    DepartmentStatus @default(ACTIVE)

  parentDepartmentId String?
  parentDepartment   Department? @relation("DepartmentToParent", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentToParent")

  departmentHeadId   String?
  departmentHead     User? @relation("DepartmentHead", fields: [departmentHeadId], references: [id])

  employees User[]
  assets    Asset[]

  createdAt DateTime @default(now())
}

model User {
  id                       String     @id @default(cuid())
  name                     String
  email                    String     @unique
  password                 String
  role                     UserRole   @default(EMPLOYEE)
  status                   UserStatus @default(ACTIVE)
  resetPasswordTokenHash   String?
  resetPasswordExpiresAt   DateTime?
  lastLoginAt              DateTime?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  headedDepartments   Department[] @relation("DepartmentHead")
  allocations         AssetAllocation[]
  transfersFrom       TransferRequest[] @relation("FromUser")
  transfersTo         TransferRequest[] @relation("ToUser")
  transferRequests    TransferRequest[] @relation("RequestedBy")
  bookings            Booking[]
  assignedMaintenance MaintenanceRecord[] @relation("TechnicianAssigned")
  assignedAudits      AuditCycle[] @relation("AssignedAudits")
  createdAudits       AuditCycle[] @relation("CreatedAudits")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

model AssetCategory {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  status      CategoryStatus @default(ACTIVE)

  assets Asset[]
}

model Asset {
  id           String @id @default(cuid())

  assetTag     String @unique
  name         String

  serialNumber String?

  acquisitionDate DateTime?
  acquisitionCost Float?
  condition       AssetCondition @default(GOOD)
  location        String?
  sharedResource  Boolean        @default(false)
  imagePath       String?
  documentPath    String?
  locationX       Float?
  locationY       Float?

  status       AssetStatus @default(AVAILABLE)

  categoryId   String
  category     AssetCategory @relation(fields: [categoryId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  allocations  AssetAllocation[]
  transfers    TransferRequest[]
  bookings     Booking[]
  maintenance  MaintenanceRecord[]
  auditItems   AuditItem[]
  history      AssetHistory[]

  createdAt    DateTime @default(now())
}

model AssetAllocation {
  id          String @id @default(cuid())

  assetId     String
  asset       Asset @relation(fields: [assetId], references: [id])

  userId      String
  user        User @relation(fields: [userId], references: [id])

  allocatedAt DateTime @default(now())
  returnDate  DateTime?
  returnedAt  DateTime?

  returned    Boolean @default(false)
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  BROKEN
}

model AssetHistory {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action      String
  details     String
  changedBy   String?
  createdAt   DateTime @default(now())
}

model TransferRequest {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromUserId    String
  fromUser      User     @relation("FromUser", fields: [fromUserId], references: [id])
  toUserId      String
  toUser        User     @relation("ToUser", fields: [toUserId], references: [id])
  status        String   @default("PENDING")
  requestedById String
  requestedBy   User     @relation("RequestedBy", fields: [requestedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Booking {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime    DateTime
  endTime      DateTime
  status       BookingStatus @default(UPCOMING)
  needReminder Boolean  @default(false)
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

model MaintenanceRecord {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  description  String
  status       MaintenanceStatus @default(PENDING)
  technicianId String?
  technician   User?    @relation("TechnicianAssigned", fields: [technicianId], references: [id])
  cost         Float?
  notes        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditCycle {
  id           String      @id @default(cuid())
  name         String
  status       String      @default("ACTIVE")
  dueDate      DateTime
  
  auditorId    String
  auditor      User        @relation("AssignedAudits", fields: [auditorId], references: [id])

  createdById  String
  createdBy    User        @relation("CreatedAudits", fields: [createdById], references: [id])

  items        AuditItem[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AuditItem {
  id           String      @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle  @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId      String
  asset        Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  verified     Boolean     @default(false)
  verifiedAt   DateTime?
  status       String      @default("PENDING")
  notes        String?
}





